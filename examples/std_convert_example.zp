import "std/convert" { toBool, toChar, toFloat64, toInt, toString };
import "std/io" { println };

fun main() Int {
  var enabled: Bool = toBool(1);
  var letter: Char = toChar(65);
  var count: Int = toInt(true);
  var ratio: Float64 = toFloat64(42);

  println(toString(enabled));
  println(toString(letter));
  println(toString(count));
  println(toString(ratio));

  return 0;
}
