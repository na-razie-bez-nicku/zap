fun main() Int {
    // Base bitwise operators
    var a: Int = 0b1010; // 10
    var b: Int = 0b1100; // 12

    var andv: Int = a & b; // 8
    if andv != 8 {
        return 1;
    }

    var orv: Int = a | b; // 14
    if orv != 14 {
        return 2;
    }

    var xorv: Int = a ^ b; // 6
    if xorv != 6 {
        return 3;
    }

    // Unsigned bitwise sanity
    var ua: UInt = 0xF0F0;
    var ub: UInt = 0x0FF0;

    var uand: UInt = ua & ub; // 0x00F0
    if uand != 0x00F0 {
        return 4;
    }

    var uor: UInt = ua | ub; // 0xFFF0
    if uor != 0xFFF0 {
        return 5;
    }

    var uxor: UInt = ua ^ ub; // 0xFF00
    if uxor != 0xFF00 {
        return 6;
    }

    // Precedence with shifts:
    // shifts bind tighter than bitwise operators in this compiler.
    var p1: Int = 1 << 3 | 2; // (1 << 3) | 2 = 10
    if p1 != 10 {
        return 7;
    }

    var p2: Int = 0b1111 ^ 1 << 2; // 15 ^ (1 << 2) = 11
    if p2 != 11 {
        return 8;
    }

    var p3: Int = 0b1111 & 3 << 1; // 15 & (3 << 1) = 6
    if p3 != 6 {
        return 9;
    }

    // Parenthesized combinations
    var c1: Int = (5 | 2) << 2; // 28
    if c1 != 28 {
        return 10;
    }

    var c2: Int = (0b1010 ^ 0b0011) >> 1; // (9) >> 1 = 4
    if c2 != 4 {
        return 11;
    }

    // Interaction with existing shifts
    var s1: Int = -16 >> 2; // arithmetic shift => -4
    if s1 != -4 {
        return 12;
    }

    var us1: UInt = 0xFFFF_FFFF >> 4; // logical shift => 0x0FFF_FFFF
    if us1 != 0x0FFF_FFFF {
        return 13;
    }

    return 0;
}
