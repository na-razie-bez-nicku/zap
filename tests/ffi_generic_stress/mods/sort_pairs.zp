import "capi";
import "generic_buf";

unsafe fun get_a(p: *capi.Pair32) Int32 {
  return (*p).a;
}

unsafe fun get_b(p: *capi.Pair32) Int32 {
  return (*p).b;
}

fun cmp(x: *Void, y: *Void) Int32 {
  unsafe {
    var px: *capi.Pair32 = x as *capi.Pair32;
    var py: *capi.Pair32 = y as *capi.Pair32;

    var ax: Int32 = get_a(px);
    var ay: Int32 = get_a(py);
    if ax < ay { return -1; }
    if ax > ay { return 1; }

    var bx: Int32 = get_b(px);
    var by: Int32 = get_b(py);
    if bx < by { return -1; }
    if bx > by { return 1; }
  }
  return 0;
}

pub fun run() Int {
  unsafe {
    var b: generic_buf.Buf<capi.Pair32> = generic_buf.alloc<capi.Pair32>(4);
    if b.ptr == null { return 21; }

    *(b.ptr + 0) = capi.Pair32 { a: 3, b: 7 };
    *(b.ptr + 1) = capi.Pair32 { a: 1, b: 9 };
    *(b.ptr + 2) = capi.Pair32 { a: 1, b: 2 };
    *(b.ptr + 3) = capi.Pair32 { a: 2, b: 1 };

    var c: *fun(*Void, *Void) Int32 = cmp;
    capi.qsort(b.ptr as *Void, b.len, 8, c);

    var p0: *capi.Pair32 = b.ptr + 0;
    var p1: *capi.Pair32 = b.ptr + 1;
    var p2: *capi.Pair32 = b.ptr + 2;
    var p3: *capi.Pair32 = b.ptr + 3;

    if get_a(p0) != 1 || get_b(p0) != 2 { generic_buf.freeBuf<capi.Pair32>(b); return 22; }
    if get_a(p1) != 1 || get_b(p1) != 9 { generic_buf.freeBuf<capi.Pair32>(b); return 23; }
    if get_a(p2) != 2 || get_b(p2) != 1 { generic_buf.freeBuf<capi.Pair32>(b); return 24; }
    if get_a(p3) != 3 || get_b(p3) != 7 { generic_buf.freeBuf<capi.Pair32>(b); return 25; }

    generic_buf.freeBuf<capi.Pair32>(b);
  }
  return 0;
}
