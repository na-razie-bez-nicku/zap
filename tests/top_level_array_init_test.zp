const NUMS: [5]Int = {0, 2, 5, 6, 7};
const MY_TUFF_CHAR: Char = 'X';
const CHARS: [5]Char = {'A', 'B', MY_TUFF_CHAR, 'C', 'D'};
global var MUTABLE: [3]Int = {3, 4, 5};

fun main() Int {
    if NUMS[1] != 2 {
        return 1;
    }
    if MUTABLE[2] != 5 {
        return 2;
    }
    MUTABLE[0] = NUMS[4];
    if MUTABLE[0] != 7 {
        return 3;
    }
    if CHARS[2] != 'X' {
        return 4;
    }
    return 0;
}
