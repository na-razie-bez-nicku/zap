struct Sample {
  a: Int,
  b: Bool,
  c: UInt8,
}

fun main() Int {
  var s0: Sample = Sample {};
  if s0.a != 0 {
    return 1;
  }
  if s0.b {
    return 2;
  }
  if s0.c != 0 {
    return 3;
  }

  var s1: Sample = Sample { a: 5 };
  if s1.a != 5 {
    return 4;
  }
  if s1.b {
    return 5;
  }
  if s1.c != 0 {
    return 6;
  }

  return 0;
}
