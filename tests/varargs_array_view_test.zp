fun sum(first: Int, rest: ...Int) Int {
    var total: Int = first;
    var i: Int = 0;
    while i < rest.len {
        total = total + rest[i];
        i = i + 1;
    }
    return total;
}

fun main() Int {
    if sum(1, 2, 3, 4, 5) != 15 {
        return 1;
    }

    if sum(9) != 9 {
        return 2;
    }

    return 0;
}
